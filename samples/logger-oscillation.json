    "script": "# === データロガー: 20 Hz の減衰振動を分析する ===\n# 0.05 秒ごと(= 20 Hz)に測った変位 displacement_m の時系列データ。\n# 目的: ロガーの密なデータを R で読み解けることを示す。\ndf <- get.input()\nt <- df$time_s\nx <- df$displacement_m\n\n# 横長の図にして時間波形を見やすくする\nset.figure(width = 8.5, height = 4.2, units = \"in\")\nset.paper_style(mar = c(4.0, 4.6, 2.2, 1.0))\n\n# (1) まず生データを線でつなぐ。20 Hz と密なので滑らかな波形に見える\nplot(t, x, type = \"l\", col = \"#1f77b4\", lwd = 1.4,\n  xlab = \"Time / s\", ylab = \"Displacement / m\",\n  main = \"Damped oscillation sampled at 20 Hz\")\nadd.paper_guides()\nabline(h = 0, col = \"#9ca3af\", lty = 2)\n\n# (2) 山(極大)をさがす: 前後の点より大きい正の点を「ピーク」とみなす\nn <- length(x)\nis_peak <- rep(FALSE, n)\nfor (i in 2:(n - 1)) {\n  if (x[i] > x[i - 1] && x[i] >= x[i + 1] && x[i] > 0) is_peak[i] <- TRUE\n}\npeak_t <- t[is_peak]\npeak_x <- x[is_peak]\npoints(peak_t, peak_x, pch = 19, col = \"firebrick\")\n\n# (3) 山の高さは指数関数で減る。両辺の log をとると時間に対して直線になる:\n#     log(振幅) = log(A0) - decay * t  ->  lm で傾き(= -decay)を求める\nfit <- lm(log(peak_x) ~ peak_t)\ndecay_rate <- -coef(fit)[2]      # 減衰の速さ [1/s]\ntau <- 1 / decay_rate            # 振幅が 1/e になるまでの時間(減衰時定数)\namp0 <- exp(coef(fit)[1])        # 初期振幅の推定値\n\n# (4) 推定した包絡線 ±amp0 * exp(-decay_rate * t) を重ねて、減衰の様子を確認\nlines(t, amp0 * exp(-decay_rate * t), col = \"#374151\", lwd = 2, lty = 2)\nlines(t, -amp0 * exp(-decay_rate * t), col = \"#374151\", lwd = 2, lty = 2)\n\n# (5) 山どうしの間隔から周期 T と振動数 f を見積もる\nperiod <- mean(diff(peak_t))\ncat(sprintf(\"decay time tau = %.2f s\\n\", tau))\ncat(sprintf(\"period T = %.3f s -> frequency = %.2f Hz\\n\", period, 1 / period))\n\nlegend(\"topright\",\n  legend = c(\"measured\", \"peaks\", \"fitted envelope\"),\n  col = c(\"#1f77b4\", \"firebrick\", \"#374151\"),\n  lty = c(1, NA, 2), pch = c(NA, 19, NA), lwd = c(1.4, NA, 2), bty = \"n\")",
