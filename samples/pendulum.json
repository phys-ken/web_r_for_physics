    "script": "df <- get.input()\nfit <- lm(period_s ~ sqrt_length_m, data = df)\nplot(df$sqrt_length_m, df$period_s,\n  pch = 19, col = \"firebrick\", cex = 1.6,\n  xlab = \"sqrt(length_m)\", ylab = \"period_s\",\n  main = \"Simple Pendulum\"\n)\narrows(df$sqrt_length_m, df$period_s - df$period_err_s,\n  df$sqrt_length_m, df$period_s + df$period_err_s,\n  angle = 90, code = 3, length = 0.05\n)\nabline(fit, col = \"navy\", lwd = 2)\nsummary(fit)",
